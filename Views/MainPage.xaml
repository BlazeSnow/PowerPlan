<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="PowerPlan.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PowerPlan.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="PowerPlan" />
            <TextBlock x:Name="SubtitleText" Foreground="Gray" Text="-" />

            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="UnlockTitleText" FontSize="18" FontWeight="SemiBold" Text="-" />
                    <TextBlock x:Name="AdminStatusText" />
                    <Button
                        x:Name="ElevateButton"
                        Click="OnElevateClicked"
                        Content="-"
                        HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock x:Name="PlansTitleText" FontSize="18" FontWeight="SemiBold" Text="-" />
                        <Button x:Name="RefreshPlansButton" Click="OnRefreshClicked" Content="-" />
                    </StackPanel>

                    <InfoBar
                        x:Name="UltimateMissingInfoBar"
                        IsOpen="False"
                        IsClosable="False"
                        Severity="Informational"
                        Title="-"
                        Message="-" />
                    <Button
                        x:Name="CreateUltimateButton"
                        Click="OnCreateUltimateClicked"
                        Content="-"
                        HorizontalAlignment="Left"
                        Visibility="Collapsed" />

                    <ListView x:Name="PlansListView">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:PowerPlanItemViewModel">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                        <TextBlock
                                            Foreground="Green"
                                            Text="{x:Bind CurrentTagText}"
                                            Visibility="{x:Bind IsActiveVisibility}" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Opacity="0.75" Text="{x:Bind Guid}" />

                                    <Button
                                        Grid.Column="2"
                                        Click="OnSwitchPlanClicked"
                                        Content="{x:Bind SwitchButtonText}"
                                        IsEnabled="{x:Bind CanSwitch}"
                                        Tag="{x:Bind Guid}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="StatusAreaTitleText" FontSize="18" FontWeight="SemiBold" Text="-" />
                    <InfoBar
                        x:Name="StatusInfoBar"
                        IsClosable="False"
                        IsOpen="True"
                        Severity="Informational"
                        Title="-"
                        Message="-" />
                </StackPanel>
            </Border>

            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="SettingsTitleText" FontSize="18" FontWeight="SemiBold" Text="-" />
                    <ToggleSwitch
                        x:Name="StartupToggle"
                        Header="-"
                        OffContent="-"
                        OnContent="-"
                        Toggled="OnStartupToggled" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>