<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="PowerPlan.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PowerPlan.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="PowerPlan" />
            <TextBlock x:Name="SubtitleText" Foreground="Gray" Text="-" />

            <Border BorderThickness="0" Padding="0">
                <StackPanel Spacing="10">

                    <InfoBar
                        x:Name="UltimateMissingInfoBar"
                        IsOpen="False"
                        IsClosable="False"
                        Severity="Informational"
                        Title="-"
                        Message="-" />
                    <Button
                        x:Name="CreateUltimateButton"
                        Click="OnCreateUltimateClicked"
                        Content="-"
                        HorizontalAlignment="Left"
                        Visibility="Collapsed" />

                    <StackPanel>
                        <Grid Padding="16,12" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock x:Name="PlanPickerTitleText" FontSize="16" FontWeight="SemiBold" Text="-" />
                            </StackPanel>
                        </Grid>

                        <ListView
                            x:Name="PlansListView"
                            SelectionMode="Single"
                            SelectionChanged="OnPlansSelectionChanged"
                            BorderThickness="0">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:PowerPlanItemViewModel">
                                    <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Padding="16,12">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0" VerticalAlignment="Top" Margin="0,2,0,0">
                                                <RadioButton
                                                    IsChecked="{x:Bind IsActive, Mode=OneWay}"
                                                    IsHitTestVisible="False"
                                                    VerticalAlignment="Top" />
                                            </Grid>

                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{x:Bind Name}" />
                                                <TextBlock FontSize="13" Opacity="0.75" Text="{x:Bind Guid}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Grid Padding="16,12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
                            <Button
                                x:Name="RefreshPlansButton"
                                Click="OnRefreshClicked"
                                Content="-"
                                HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <InfoBar
                x:Name="StatusInfoBar"
                IsClosable="False"
                IsOpen="True"
                Severity="Informational"
                Title="-"
                Message="-" />
        </StackPanel>
    </ScrollViewer>
</Page>
